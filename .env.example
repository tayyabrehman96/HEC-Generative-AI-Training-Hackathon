# Regolo AI — required for the Express proxy (server.js).
# Get a key from https://regolo.ai/ — never commit real keys.
# Use the raw key only (sk-…). Do NOT add "Bearer " here — server adds it.
# Do NOT wrap in quotes unless your tooling requires it.
REGOLO_API_KEY=

# Optional: OpenAI-compatible base (no trailing slash). Default: https://api.regolo.ai/v1
# REGOLO_API_BASE_URL=https://api.regolo.ai/v1

# Optional: retries when the upstream connection fails (1–4). Default: 3
# REGOLO_FETCH_RETRIES=3

# Optional: max time to wait for each Regolo completion (ms). Default: 1200000 (20 min). Max cap: 2700000 (45 min). Large VLM (e.g. qwen3.5-122b) may need 1800000+.
# REGOLO_FETCH_TIMEOUT_MS=1200000

# Optional: if the front-end is hosted separately from the proxy, set your API **origin**
# (with or without `/proxy` — the app will append `/proxy` when missing). Leave unset for same-origin builds.
# VITE_API_BASE_URL=https://your-service.up.railway.app
