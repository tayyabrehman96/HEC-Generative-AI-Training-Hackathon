# Regolo AI — required for the Express proxy (server.js).
# Get a key from https://regolo.ai/ — never commit real keys.
REGOLO_API_KEY=

# Optional: split deploy only — full base URL to API (must end with /proxy or equivalent).
# VITE_API_BASE_URL=https://your-api.example.com

# Local: npm script sets PROXY_ONLY=1 so Express does not serve dist/ next to Vite.
# Hosted: NODE_ENV=production + build output in dist/ — see DEPLOY_PUBLIC_DEMO.md
