# Regolo AI — required for the Express proxy (server.js).
# Get a key from https://regolo.ai/ — never commit real keys.
REGOLO_API_KEY=

# Optional: if the front-end is hosted separately from the proxy,
# set the full base URL to your deployed API (must end path with /proxy or equivalent).
# VITE_API_BASE_URL=https://your-api.example.com
